# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env

# Obrigatorias (para exemplos de e-mail)
NYLAS_API_KEY=
NYLAS_GRANT_ID= 

# Autenticacao (auth_flow.py)
NYLAS_REDIRECT_URI=http://localhost:5000/oauth/callback
NYLAS_CLIENT_ID=
NYLAS_PROVIDER=
NYLAS_LOGIN_HINT=

# Opcionais
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_INBOX_FOLDER_ID=
NYLAS_PROCESSED_FOLDER_ID=
NYLAS_SUBJECT_FILTER=
# Filtro client-side por nome de anexo (substring, case-insensitive).
# Pode ser combinado com unread, has_attachment, in_, etc. (não usa search_query_native).
# Ex.: .pdf  ou  invoice.xlsx
NYLAS_ATTACHMENT_FILENAME_FILTER=
