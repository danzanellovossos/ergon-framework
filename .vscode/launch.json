{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File (Windows)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/Scripts/python",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"},
        },
        {
            "name": "Python Debugger: Current File (Mac OS)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"},
        },
        {
            "name": "Examples (Windows)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/sdks/python/.venv/Scripts/python",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"},
        },
        {
            "name": "Nylas: auth_flow (generate-url)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sdks/python/examples/nylas/auth_flow.py",
            "args": ["--generate-url"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/sdks/python",
            "python": "${workspaceFolder}/sdks/python/.venv/Scripts/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/sdks/python/src"
            },
            "envFile": "${workspaceFolder}/sdks/python/examples/nylas/.env"
        },
        {
            "name": "Nylas: auth_flow (exchange-code)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sdks/python/examples/nylas/auth_flow.py",
            "args": ["--exchange-code", "DHvf8zEujTHW_ih_LqkmF7LuKawfEDwYcFI50d4h1YsS4ItKpgV8X3-DstggdyMkwH5Wn21qNrEMWD4xVPAVBYGFtxDYA7A7"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/sdks/python",
            "python": "${workspaceFolder}/sdks/python/.venv/Scripts/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/sdks/python/src"
            },
            "envFile": "${workspaceFolder}/sdks/python/examples/nylas/.env"
        },
    ],
}